# Supabase 인증 (Google OAuth)
#
# 이 두 값은 공개용이며 빌드 시 클라이언트 번들에 인라인된다(브라우저에 노출 정상).
# 값 출처: Supabase 대시보드 → Project Settings → API
#
# 로컬 개발: 이 파일을 `.env.local` 로 복사하고 실제 값을 채운다(.env.local 은 gitignore).
# CI(GitHub Actions): repo → Settings → Secrets and variables → Actions → Variables 에 등록.

NEXT_PUBLIC_SUPABASE_URL=https://ubkcexwugcyixflqnhgr.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# 프로필 이미지 다운로드 URL의 **앞부분**(스토리지 주소 + 버킷명).
# 전체 URL = 이 값 + "/" + profile.image_path(= 버킷 이후 경로, uuidv4 파일명).
# 예) https://<ref>.supabase.co/storage/v1/object/public/profile-image/3f2a....png
# 값 출처: Supabase 대시보드 → Storage → profile-image 버킷의 파일 → Get URL 에서
#          버킷명까지만 잘라 쓴다. 끝에 슬래시를 붙여도 무해하다.
NEXT_PUBLIC_SUPABASE_STORAGE_URL=https://ubkcexwugcyixflqnhgr.supabase.co/storage/v1/object/public/profile-image
